# Terraform state — NEVER commit state files (contain secrets + resource IDs)
**/.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
crash.log
override.tf
override.tf.json

# tfvars may contain sensitive values (IPs, CIDRs)
# Keep only the example file, not the real one
*.tfvars
!*.tfvars.example

# SSH private keys — NEVER commit
*.pem
*.key
id_rsa
id_ed25519

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Claude Code internal
.claude/
